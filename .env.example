# Copy this file to ".env" and fill in your values.
# .env is gitignored — never commit your real API key.

# Roboflow API key (Workspace > Settings > API)
ROBOFLOW_API_KEY=rf_xxxxxxxxxxxxxxxxxxxxxxxx

# ---- Player detection dataset IDs ----
# Find these in the Roboflow URL: app.roboflow.com/<workspace>/<project>/<version>
ROBOFLOW_PLAYER_WORKSPACE=your-workspace
ROBOFLOW_PLAYER_PROJECT=padel-players
ROBOFLOW_PLAYER_VERSION=1

# ---- Court keypoints dataset IDs ----
ROBOFLOW_COURT_WORKSPACE=your-workspace
ROBOFLOW_COURT_PROJECT=padel-court-keypoints
ROBOFLOW_COURT_VERSION=1
